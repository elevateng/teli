# Copy to .env and fill in. All optional — without them the app runs in dev/sandbox mode.

# Server
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
APP_URL=http://localhost:5173

# --- Payments ---
# The app uses Flutterwave if FLW_SECRET_KEY is set, otherwise Paystack, otherwise
# a built-in sandbox. Use TEST keys to try the real flow without charging money.

# Flutterwave (https://dashboard.flutterwave.com -> Settings -> API Keys)
FLW_SECRET_KEY=
FLW_PUBLIC_KEY=
FLW_SECRET_HASH=

# Paystack (https://dashboard.paystack.com/#/settings/developers)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Web application OAuth client ID. Leave empty to use the local dev-Google fallback.
GOOGLE_CLIENT_ID=

# Email / SMTP (e.g. Resend, SendGrid, Mailgun, Gmail). Leave SMTP_HOST blank to
# run in dev mode (emails are logged + viewable in the admin "Email log", not sent).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=TELI <no-reply@teli.africa>
